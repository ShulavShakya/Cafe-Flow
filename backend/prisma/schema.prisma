// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Role {
  role_id    Int      @id @default(autoincrement())
  role_name  String   @unique
  description String?
  users      User[]
  created_at DateTime @default(now())
}

model User {
  user_id     Int      @id @default(autoincrement())

  full_name   String
  email       String   @unique
  password    String
  phone       String? @unique
  address     String?

  role_id     Int
  status      String   @default("active")

  salary      Float? @default(0)

  must_change_password Boolean @default(true)
  temp_password Boolean @default(false)
  refresh_token String? @db.Text

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  role        Role     @relation(fields: [role_id], references: [role_id])

  billings    Billing[]
  payments    Payment[]
}

model Guest {
  guest_id   Int      @id @default(autoincrement())
  full_name  String
  phone      String? @unique
  created_at DateTime @default(now())

  room_reservations RoomReservation[]
  food_orders FoodOrder[]
  billings   Billing[]

  tableReservations TableReservation[]
}

model Room {
  room_id           Int      @id @default(autoincrement())
  room_number       String   @unique
  category          String?
  capacity          Int
  price_per_night   Float
  status            String   @default("available")
  created_at        DateTime @default(now())

  room_reservations RoomReservation[]
  billings Billing[]
}

model RoomReservation {
  room_reservation_id        Int      @id @default(autoincrement())
  guest_id       Int
  room_id        Int
  guest_count     Int?
  check_in_date  DateTime
  check_in_time  DateTime
  check_out_date   DateTime?
  status         String   @default("active")
  type           String   @default("reservation") 
  created_at     DateTime @default(now())
  guest          Guest    @relation(fields: [guest_id], references: [guest_id])
  room           Room     @relation(fields: [room_id], references: [room_id])
  billings       Billing[]
}

model Table {
  table_id     Int      @id @default(autoincrement())
  table_number String   @unique
  capacity     Int      @default(2)
  status       String   @default("Available")

  food_orders  FoodOrder[]
  billings     Billing[]

  tableReservations TableReservation[]
}

model TableReservation {
  table_reservation_id   Int      @id @default(autoincrement())
  guest_id         Int?
  table_id         Int
  reservation_date DateTime
  reservation_time String
  guest_count      Int?
  status           String   @default("active")
  type             String   @default("reservation")
  created_at       DateTime @default(now())

  guest            Guest?    @relation(fields: [guest_id], references: [guest_id])
  table            Table    @relation(fields: [table_id], references: [table_id])
  billings         Billing[]

  foodOrders FoodOrder[]
}

model MenuCategory {
  category_id   Int      @id @default(autoincrement())
  name          String
  menu_items    MenuItem[]
}

model MenuItem {
  menu_item_id  Int      @id @default(autoincrement())
  name          String
  price         Float
  available_status String   @default("available")
  category_id   Int

  category      MenuCategory @relation(fields: [category_id], references: [category_id])
  order_items   FoodOrderItem[]
}

model FoodOrder {
  food_order_id Int      @id @default(autoincrement())
  table_id      Int
  guest_id      Int?
  status        String   @default("preparing")
  customizations String?
  created_at    DateTime @default(now())
  table_reservation_id Int?

  table         Table    @relation(fields: [table_id], references: [table_id])
  guest         Guest?   @relation(fields: [guest_id], references: [guest_id])
  table_reservation TableReservation? @relation(fields: [table_reservation_id], references: [table_reservation_id])

  items         FoodOrderItem[]
  billings      Billing[]
}

model FoodOrderItem {
  id             Int      @id @default(autoincrement())
  food_order_id  Int
  menu_item_id   Int
  quantity       Int
  unit_price     Float

  food_order     FoodOrder @relation(fields: [food_order_id], references: [food_order_id])
  menu_item      MenuItem  @relation(fields: [menu_item_id], references: [menu_item_id])
}

model Inventory {
  id             Int      @id @default(autoincrement())
  
  supplier_name  String
  category       String
  company        String
  contact_number String   @unique
  email_address  String   @unique
  address        String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Billing {
  bill_id        Int      @id @default(autoincrement())

  bill_type      BillType

  room_reservation_id Int?
  table_reservation_id Int?
  food_order_id  Int?

  table_number Int?
  room_number Int?
  customer_name String?
  payment_method String?
  generated_by_user_id Int

  bill_status    BillStatus @default(PENDING)

  room_charges   Float @default(0)
  food_charges   Float @default(0)
  tax_amount     Float @default(0)
  discount_amount Float @default(0)
  total_amount   Float

  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  room_reservation RoomReservation? @relation(fields: [room_reservation_id], references: [room_reservation_id])
  table_reservation TableReservation? @relation(fields: [table_reservation_id], references: [table_reservation_id])
  food_order  FoodOrder? @relation(fields: [food_order_id], references: [food_order_id])

  generated_by User @relation(fields: [generated_by_user_id], references: [user_id])

  payments    Payment[]

  tables Table[]

  rooms Room[]

  guests Guest[]
}

model Payment {
  payment_id Int      @id @default(autoincrement())

  bill_id    Int
  received_by_user_id Int

  payment_method PaymentMethod
  amount     Float

  reference_number String?
  notes      String?

  payment_status PaymentStatus @default(COMPLETED)

  paid_at    DateTime @default(now())

  billing    Billing @relation(fields: [bill_id], references: [bill_id])
  user       User    @relation(fields: [received_by_user_id], references: [user_id])
}

enum BillType {
  Food
  Room
  Table
  Combined
}

enum BillStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  Cash
  Qr
  bank_transfer
  complimentary
}

enum PaymentStatus {
  COMPLETED
  PENDING
  FAILED
  REFUNDED
}